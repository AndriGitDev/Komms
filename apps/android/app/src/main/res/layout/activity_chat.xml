<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/chat_toolbar"
        android:background="@color/primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_messages"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:id="@+id/chat_attachment_section"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingHorizontal="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="@string/attachment_transfers_title"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chat_attachments"
            android:nestedScrollingEnabled="false"
            android:layout_width="match_parent"
            android:layout_height="180dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chat_scheduled_section"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/warning_surface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="@string/scheduled_outbox_title"
            android:textStyle="bold"
            android:textColor="@color/warning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/chat_scheduled"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/chat_attach"
            android:text="@string/chat_attach"
            android:contentDescription="@string/chat_attach"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/chat_record"
            android:text="@string/audio_record"
            android:contentDescription="@string/audio_record_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/chat_mention"
            android:text="@string/mention_member"
            android:contentDescription="@string/mention_member_description"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <komms.android.IncognitoEditText
            android:id="@+id/chat_input"
            android:hint="@string/chat_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/chat_schedule"
            android:text="@string/chat_schedule"
            android:contentDescription="@string/chat_schedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/chat_send"
            android:text="@string/chat_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/chat_mention_tokens_scroll"
        android:visibility="gone"
        android:fillViewport="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/chat_mention_tokens"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/chat_mention_status"
        android:visibility="gone"
        android:accessibilityLiveRegion="polite"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp"
        android:textSize="12sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/chat_recording_status"
        android:accessibilityLiveRegion="polite"
        android:visibility="invisible"
        android:layout_width="1dp"
        android:layout_height="1dp" />
</LinearLayout>
