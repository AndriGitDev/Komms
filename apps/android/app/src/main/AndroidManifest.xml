<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The node speaks QUIC/TCP itself; no Google services involved. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- QR pairing and safety-number verification. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Foreground-only recorded audio messages; never background capture. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Keep the node delivering while the app is backgrounded. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <application
        android:name=".KommsApp"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.Komms"
        android:allowBackup="false">
        <!-- allowBackup=false: the store is passphrase-encrypted, but the OS
             backup pipeline (Google servers) must never see it at all.
             Portability is the user-held encrypted .kkr backup instead. -->

        <activity android:name=".GateActivity" android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".MainActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".AddContactActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ChatActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".NoteToSelfActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".GroupChatActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".VerifyActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ScanActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".SettingsActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".DeviceActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".LabelManagerActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".FolderManagerActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".CustomIconActivity" android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <service
            android:name=".NodeService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.files"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
