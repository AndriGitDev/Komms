{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Komms",
  "version": "0.2.0",
  "identifier": "is.andri.komms",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Komms",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560,
        "contentProtected": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "app", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Serverless E2EE messenger over internet, LAN, and LoRa mesh",
    "longDescription": "Komms is a sovereign messenger: end-to-end encrypted with hybrid post-quantum key agreement, server-independent at its core, and functional over the internet, LAN, commodity LoRa radios, or file sneakernet. No account, phone number, or project-operated service is required."
  }
}
