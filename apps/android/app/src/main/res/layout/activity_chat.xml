<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/chat_toolbar"
        android:background="@color/primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize" />

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/chat_call"
            android:text="@string/call_start"
            android:contentDescription="@string/call_start_description"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/chat_call_status"
            android:accessibilityLiveRegion="polite"
            android:paddingStart="12dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_messages"
        android:paddingHorizontal="8dp"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <ScrollView
        android:id="@+id/chat_poll_section"
        android:visibility="gone"
        android:fillViewport="true"
        android:paddingHorizontal="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/chat_polls"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/chat_attachment_section"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingHorizontal="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/chat_attachment_toggle"
            android:text="@string/attachment_transfers_title"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:paddingVertical="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chat_attachments"
            android:nestedScrollingEnabled="false"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="180dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chat_scheduled_section"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@color/warning_surface"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="@string/scheduled_outbox_title"
            android:textStyle="bold"
            android:textColor="@color/warning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/chat_scheduled"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Disappearing-message state: a compact chip while the picker row is
         tucked away in the "+" menu. Tapping re-opens the row. -->
    <TextView
        android:id="@+id/chat_ephemeral_chip"
        android:visibility="gone"
        android:textSize="12sp"
        android:textColor="@color/accent"
        android:paddingHorizontal="12dp"
        android:paddingVertical="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <!-- Hidden until toggled from the "+" menu; the spinner stays the
         single source of truth read at send time. -->
    <LinearLayout
        android:id="@+id/chat_ephemeral_section"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:paddingHorizontal="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="@string/ephemeral_remove_after"
            android:labelFor="@id/chat_ephemeral_lifetime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Spinner
            android:id="@+id/chat_ephemeral_lifetime"
            android:contentDescription="@string/ephemeral_remove_after"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/chat_ephemeral_honesty"
            android:text="@string/ephemeral_honesty"
            android:textSize="11sp"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:paddingVertical="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/chat_more"
            android:src="@drawable/ic_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/chat_more_actions"
            android:layout_width="44dp"
            android:layout_height="44dp" />

        <ImageButton
            android:id="@+id/chat_attach"
            android:src="@drawable/ic_attach"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/chat_attach"
            android:layout_width="44dp"
            android:layout_height="44dp" />

        <komms.android.IncognitoEditText
            android:id="@+id/chat_input"
            android:hint="@string/chat_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:minHeight="44dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content" />

        <ImageButton
            android:id="@+id/chat_record"
            android:src="@drawable/ic_mic"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/audio_record_description"
            android:layout_width="44dp"
            android:layout_height="44dp" />

        <ImageButton
            android:id="@+id/chat_send"
            android:src="@drawable/ic_send"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/chat_send"
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <!-- Never drawn: an action registry for the "+" menu. Child visibility
         still carries availability (groups enable mention/poll), and menu
         items delegate to these buttons' existing click handlers, so the
         activities' and controllers' wiring is untouched. -->
    <LinearLayout
        android:id="@+id/chat_hidden_actions"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="0dp">

        <Button
            android:id="@+id/chat_schedule"
            android:text="@string/chat_schedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/chat_mention"
            android:text="@string/mention_member"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/chat_poll"
            android:text="@string/poll_create_action"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/chat_mention_tokens_scroll"
        android:visibility="gone"
        android:fillViewport="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/chat_mention_tokens"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/chat_mention_status"
        android:visibility="gone"
        android:accessibilityLiveRegion="polite"
        android:paddingHorizontal="12dp"
        android:paddingBottom="4dp"
        android:textSize="12sp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/chat_recording_status"
        android:accessibilityLiveRegion="polite"
        android:visibility="invisible"
        android:layout_width="1dp"
        android:layout_height="1dp" />
</LinearLayout>
