<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/main_toolbar"
        android:background="@color/primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize" />

    <TextView
        android:id="@+id/main_status"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView android:text="@string/folders_title" android:textStyle="bold" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" />
        <Button android:id="@+id/main_manage_folders" style="?attr/borderlessButtonStyle" android:text="@string/folders_manage" android:textAllCaps="false" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </LinearLayout>

    <HorizontalScrollView
        android:fillViewport="true"
        android:scrollbars="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RadioGroup
            android:id="@+id/main_folder_filters"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </HorizontalScrollView>

    <TextView
        android:id="@+id/main_folder_filter_status"
        android:accessibilityLiveRegion="polite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:text="@string/label_filter_heading"
            android:textStyle="bold"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content" />
        <Button
            android:id="@+id/main_manage_labels"
            style="?attr/borderlessButtonStyle"
            android:text="@string/labels_manage"
            android:textAllCaps="false"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <HorizontalScrollView
        android:fillViewport="true"
        android:scrollbars="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@+id/main_label_filters"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </HorizontalScrollView>

    <RadioGroup
        android:id="@+id/main_label_filter_mode"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RadioButton
            android:id="@+id/main_label_filter_any"
            android:text="@string/label_filter_any"
            android:checked="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <RadioButton
            android:id="@+id/main_label_filter_all"
            android:text="@string/label_filter_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </RadioGroup>

    <Button
        android:id="@+id/main_label_filter_clear"
        style="?attr/borderlessButtonStyle"
        android:text="@string/label_filter_clear"
        android:textAllCaps="false"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/main_label_filter_status"
        android:accessibilityLiveRegion="polite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/main_empty"
        android:text="@string/main_empty"
        android:visibility="gone"
        android:padding="24dp"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/main_note_to_self"
        style="?attr/borderlessButtonStyle"
        android:text="@string/note_to_self_title"
        android:textAllCaps="false"
        android:textAlignment="viewStart"
        android:paddingHorizontal="16dp"
        android:contentDescription="@string/note_to_self_local"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:text="@string/main_contacts_heading"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/main_contacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:text="@string/main_groups_heading"
        android:textStyle="bold"
        android:textSize="18sp"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/main_groups_empty"
        android:text="@string/main_groups_empty"
        android:visibility="gone"
        android:paddingHorizontal="24dp"
        android:paddingVertical="8dp"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/main_groups"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
