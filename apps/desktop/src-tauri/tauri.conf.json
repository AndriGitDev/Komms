{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Komms",
  "version": "0.1.0",
  "identifier": "is.andri.komms",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Komms",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"],
    "category": "Network",
    "shortDescription": "Serverless E2EE messenger over internet, LAN, and LoRa mesh"
  }
}
